---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getReadingTime } from "@/utils/getReadingTime";
import IconHash from "@/assets/icons/IconHash.svg";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath, body } = Astro.props;

const { title, description, tags, ...props } = data;
const { minutes } = getReadingTime(body);
const visibleTags = (tags ?? []).slice(0, 5);
---

<li
  class:list={[
    "group relative -mx-3 my-3 rounded-lg p-3",
    "transition-all duration-300 ease-in-out",
    "hover:-translate-y-1 hover:bg-muted/20 hover:shadow-md border border-transparent hover:border-border/50",
  ]}
>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent transition-colors duration-300",
      "decoration-dashed underline-offset-4 group-hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <div
    class="my-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm opacity-70 transition-opacity duration-300 group-hover:opacity-100"
  >
    <Datetime {...props} />
    <span aria-hidden="true" class="select-none">·</span>
    <span class="whitespace-nowrap" title={`约 ${minutes} 分钟阅读`}>
      📖 约 {minutes} 分钟
    </span>
  </div>
  <p class="opacity-80 transition-opacity duration-300 group-hover:opacity-100">{description}</p>
  {
    visibleTags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {visibleTags.map(tag => (
          <li>
            <span
              class:list={[
                "inline-flex items-center gap-1",
                "rounded-full border border-border bg-muted/20 px-2.5 py-0.5 text-xs font-medium",
                "opacity-80 transition-all duration-300 group-hover:border-accent/30 group-hover:opacity-100 group-hover:bg-muted/40",
              ]}
            >
              <IconHash class="size-3" />
              {tag}
            </span>
          </li>
        ))}
      </ul>
    )
  }
</li>
